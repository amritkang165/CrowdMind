{
  "version": 2,
  "installCommand": "cd apps/api && npm install",
  "buildCommand": "cd apps/api && npm run build",
  "builds": [
    {
      "src": "apps/api/dist/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/dist/app.js"
    }
  ]
}